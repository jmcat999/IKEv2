# 只用这个选择当前运行模式：nat 或 proxyarp
# 两套模式配置可以同时写在本文件里，实际只会使用 VPN_MODE 选中的那一套。
VPN_MODE=nat

VPN_DOMAIN=cat66.cn
VPN_USER=2654603465
VPN_PASSWORD=ChangeThisPassword123!

# =========================
# NAT 模式配置
# =========================
# NAT 模式：VPN 客户端使用独立网段，通过 MASQUERADE/NAT 访问内网和外网。
NAT_VPN_POOL=10.66.0.0/24
NAT_DNS1=1.1.1.1
NAT_DNS2=8.8.8.8
# NAT_LOCAL_TS 默认 0.0.0.0/0，表示客户端默认走全局隧道。
# NAT_LOCAL_TS=0.0.0.0/0

# =========================
# Proxy ARP 同网段模式配置
# =========================
# Proxy ARP 模式：VPN 客户端使用局域网同网段地址，不做 NAT。
# 支持 CIDR：192.168.0.240/28
# 支持范围：192.168.0.180-192.168.0.200
# 这段地址必须在路由器 DHCP 里排除，不能和已有设备冲突。
PROXYARP_VPN_POOL=192.168.0.240/28

# 下发给 VPN 客户端的 DNS。
# 如果不填 PROXYARP_DNS1，脚本会从 PROXYARP_VPN_POOL 自动推导，例如 192.168.0.240/28 -> 192.168.0.1。
# 如果你的网关/DNS 不是 .1，请手动填写。
# PROXYARP_DNS1=192.168.0.1
# PROXYARP_DNS2=1.1.1.1

# 高级可选：Proxy ARP 使用的局域网网段。
# 默认会从 PROXYARP_VPN_POOL 自动推导：
#   192.168.0.240/28 -> 192.168.0.0/24
#   192.168.0.180-192.168.0.200 -> 192.168.0.0/24
# 只有你的局域网不是 /24，或者需要手动指定时才需要取消注释。
# PROXYARP_LAN_SUBNET=192.168.0.0/24

# 高级可选：下发给客户端的流量选择器 local_ts。
# 默认等于 PROXYARP_LAN_SUBNET，表示客户端只把局域网流量走 VPN。
# 例如默认是 192.168.0.0/24。
# 一般不要改；只有想让客户端全局流量也走 VPN 时，才考虑改成 0.0.0.0/0。
# PROXYARP_LOCAL_TS=192.168.0.0/24
