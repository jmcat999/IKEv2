# nat: 默认模式，VPN 客户端使用独立网段，通过 MASQUERADE/NAT 访问内网和外网。
# proxyarp: 高级模式，VPN 客户端使用局域网同网段地址，不做 NAT，通过 Proxy ARP 暴露给 LAN。
VPN_MODE=nat

VPN_DOMAIN=cat66.cn
VPN_USER=2654603465
VPN_PASSWORD=ChangeThisPassword123!

# NAT 模式推荐：10.66.0.0/24
# Proxy ARP 模式示例：192.168.0.240/28，必须避开路由器 DHCP 地址池和已有设备 IP。
VPN_POOL=10.66.0.0/24

VPN_DNS1=1.1.1.1
VPN_DNS2=8.8.8.8

# Proxy ARP 模式使用，填写你的局域网网段。
LAN_SUBNET=192.168.0.0/24

# 可选：覆盖服务端下发的 local_ts。
# NAT 默认 0.0.0.0/0，Proxy ARP 默认 LAN_SUBNET。
# VPN_LOCAL_TS=0.0.0.0/0
